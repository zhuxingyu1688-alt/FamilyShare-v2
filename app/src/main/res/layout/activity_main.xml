<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="18dp"
        android:paddingEnd="20dp"
        android:paddingBottom="22dp">

        <!-- 标题区 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🏠"
                android:textSize="38sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="家庭共享"
                android:textColor="@color/text_primary"
                android:textSize="32sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="只在到点或手动测试时定位，发送后自动停止 · 双定时版"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:layout_marginTop="6dp" />
        </LinearLayout>

        <!-- ──────── 接收地址 ──────── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/card_bg"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            android:layout_marginBottom="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="接收地址"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/et_url"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="86dp"
                    android:hint="https://open.feishu.cn/open-apis/bot/v2/hook/..."
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:background="@color/input_bg"
                    android:padding="13dp"
                    android:textSize="13sp"
                    android:gravity="top|start"
                    android:inputType="textUri|textMultiLine|textNoSuggestions"
                    android:singleLine="false"
                    android:minLines="2"
                    android:maxLines="3"
                    android:scrollHorizontally="false"
                    android:importantForAutofill="no" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="飞书机器人关键词建议：位置。签名和 IP 白名单先关闭。"
                    android:textColor="@color/text_hint"
                    android:textSize="12sp"
                    android:lineSpacingExtra="3dp"
                    android:layout_marginTop="8dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ──────── 定时 1 ──────── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/card_bg"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="定时 ①"
                    android:textColor="@color/accent"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="小时"
                        android:textColor="@color/text_hint"
                        android:textSize="12sp" />
                    <Space android:layout_width="28dp" android:layout_height="1dp" />
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="分钟"
                        android:textColor="@color/text_hint"
                        android:textSize="12sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="130dp"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:background="@color/picker_bg"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp">

                    <NumberPicker
                        android:id="@+id/np_hour"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:theme="@style/NumberPickerReadable" />

                    <TextView
                        android:layout_width="28dp"
                        android:layout_height="match_parent"
                        android:text=":"
                        android:textColor="@color/text_primary"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:gravity="center" />

                    <NumberPicker
                        android:id="@+id/np_minute"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:theme="@style/NumberPickerReadable" />
                </LinearLayout>

                <Button
                    android:id="@+id/btn_save_time"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:text="保存定时 ① 并清理旧闹钟"
                    android:textColor="@color/btn_text"
                    android:backgroundTint="@color/save_btn_bg"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginTop="12dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ──────── 定时 2 ──────── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/card_bg"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            android:layout_marginBottom="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="定时 ②"
                    android:textColor="@color/accent"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="小时"
                        android:textColor="@color/text_hint"
                        android:textSize="12sp" />
                    <Space android:layout_width="28dp" android:layout_height="1dp" />
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="分钟"
                        android:textColor="@color/text_hint"
                        android:textSize="12sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="130dp"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:background="@color/picker_bg"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp">

                    <NumberPicker
                        android:id="@+id/np_hour2"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:theme="@style/NumberPickerReadable" />

                    <TextView
                        android:layout_width="28dp"
                        android:layout_height="match_parent"
                        android:text=":"
                        android:textColor="@color/text_primary"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:gravity="center" />

                    <NumberPicker
                        android:id="@+id/np_minute2"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:theme="@style/NumberPickerReadable" />
                </LinearLayout>

                <Button
                    android:id="@+id/btn_save_time2"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:text="保存定时 ② 并清理旧闹钟"
                    android:textColor="@color/btn_text"
                    android:backgroundTint="@color/save_btn_bg"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginTop="12dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ──────── 主操作按钮 ──────── -->
        <Button
            android:id="@+id/btn_toggle"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="⚪  开启每日 06:00 / 20:00 发送"
            android:textColor="@color/btn_text"
            android:backgroundTint="@color/btn_bg"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="10dp" />

        <Button
            android:id="@+id/btn_test"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="立即发送一次（测试）"
            android:textColor="@color/btn_text"
            android:backgroundTint="@color/accent"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginBottom="10dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">

            <Button
                android:id="@+id/btn_pause_today"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="今日暂停"
                android:textColor="@color/btn_text"
                android:backgroundTint="@color/pause_btn_bg"
                android:textSize="13sp"
                android:textStyle="bold" />

            <Space android:layout_width="10dp" android:layout_height="1dp" />

            <Button
                android:id="@+id/btn_stop_service"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="立即停止定位"
                android:textColor="@color/btn_text"
                android:backgroundTint="@color/danger_btn_bg"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <Button
            android:id="@+id/btn_self_check"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="权限自检 / 后台保活检查"
            android:textColor="@color/btn_text"
            android:backgroundTint="@color/save_btn_bg"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="18dp" />

        <!-- ──────── 状态面板 ──────── -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/status_bg"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tv_state"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/accent"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tv_next_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:layout_marginBottom="2dp" />

                <TextView
                    android:id="@+id/tv_next_time2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tv_last_sent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="尚未发送过"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tv_last_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:layout_marginTop="4dp" />

                <TextView
                    android:id="@+id/tv_last_wake"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_hint"
                    android:textSize="12sp"
                    android:layout_marginTop="8dp" />

                <TextView
                    android:id="@+id/tv_last_location_access"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_hint"
                    android:textSize="12sp"
                    android:layout_marginTop="4dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💡 说明：最多两个定时，可在「到点时间窗口」或手动测试时访问定位；开机恢复、切后台不会定位。发送成功/失败后自动停止。强行停止 App 后，Android 不允许它自己复活。"
            android:textColor="@color/text_hint"
            android:textSize="12sp"
            android:lineSpacingExtra="4dp"
            android:layout_marginTop="20dp" />
    </LinearLayout>
</ScrollView>
